{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "bottechdocs",
  "main": "./worker/index.js",
  "compatibility_date": "2026-04-20",
  "assets": {
    "directory": "./frontend/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "build": {
    "command": "npm ci && npm run build",
    "cwd": "./frontend"
  }
}
