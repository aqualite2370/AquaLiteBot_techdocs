[Unit]
Description=AquaLiteBot Tech Docs FastAPI Service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/aqualitebot-techdocs/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=/var/www/aqualitebot-techdocs/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
